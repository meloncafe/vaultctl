{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "schedule:weekly"
  ],
  "rebaseWhen": "behind-base-branch",
  "rangeStrategy": "bump",
  "labels": [
    "dependencies"
  ],
  "packageRules": [
    {
      "description": "Python version - disable auto update",
      "matchManagers": [
        "poetry",
        "github-actions"
      ],
      "matchDepNames": [
        "python"
      ],
      "enabled": false
    },
    {
      "description": "Python dependencies - group minor/patch",
      "matchManagers": [
        "poetry"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "python dependencies",
      "automerge": true
    },
    {
      "description": "Python major updates - separate PRs",
      "matchManagers": [
        "poetry"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false,
      "labels": [
        "dependencies",
        "major-update"
      ]
    },
    {
      "description": "Security updates - high priority",
      "matchCategories": [
        "security"
      ],
      "prPriority": 10,
      "automerge": false
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": [
      "security"
    ]
  },
  "automergeStrategy": "squash"
}
